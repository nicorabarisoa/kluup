# Supabase — copy to .env.local for local dev, and set the SAME vars in your
# host's dashboard (Railway → Variables) for production.
#
# IMPORTANT: NEXT_PUBLIC_* vars are inlined at BUILD time by Next.js. If they
# are missing when the app is built, the app ships with undefined values and
# every Supabase request fails. After setting them on Railway you must trigger
# a new build/deploy for the change to take effect.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
